# Environment variables for TrustLens Backend
# Copy to .env and fill in real values. NEVER commit .env to git.

PORT=5000
NODE_ENV=development

# MongoDB
MONGODB_URI=mongodb+srv://<username>:<password>@cluster0.xxxxx.mongodb.net/trustlens?retryWrites=true&w=majority

# JWT
JWT_SECRET=replace_with_a_long_random_secret_string
JWT_EXPIRES_IN=7d

# Google Gemini API (used for AI fraud reports)
# Get your key at https://aistudio.google.com → Get API Key
GOOGLE_API_KEY=AIzaSy_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ML Service URL
ML_SERVICE_URL=http://localhost:5001

# Frontend URL (for CORS)
FRONTEND_URL=http://localhost:5173
